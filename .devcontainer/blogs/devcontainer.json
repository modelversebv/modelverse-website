{
  "name": "Blog Editor",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:24",

  "workspaceFolder": "/workspaces/modelverse-website",

  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "SanaAjani.taskrunnercode",
        "unifiedjs.vscode-mdx"
      ],

      "settings": {
        "task.autoDetect": "off",
        "workbench.startupEditor": "none",
        "editor.wordWrap": "on",
        "terminal.integrated.defaultProfile.linux": "bash",

        "[mdx]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[markdown]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        }
      }
    }
  },

  "postCreateCommand": "cd /workspaces/modelverse-website && npm ci",
  "postStartCommand": "code /workspaces/modelverse-website/blogs.code-workspace",

  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "openBrowser"
    }
  },

  "remoteUser": "node"
}
